{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information including role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "username", "email", "role"]
    },
    "Entry": {
      "title": "Entry",
      "description": "A cringe story entry.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorUsername": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" },
        "cringeScore": { "type": "number" },
        "cringeCount": { "type": "number" }
      },
      "required": ["content", "authorId", "authorUsername", "status", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback message.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorEmail": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["content", "authorId", "authorEmail", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/entries/{entryId}": {
      "schema": "Entry",
      "description": "Collection of cringe entries."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of user feedback."
    }
  }
}
